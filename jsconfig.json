{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["resources/js/*"],
            "ziggy-js": ["./vendor/tightenco/ziggy/src/js/index"]
        }
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "public", "vendor"]
}
