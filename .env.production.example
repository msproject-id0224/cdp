APP_NAME=CDP-MSProject
APP_ENV=production
APP_KEY=                          # akan di-generate otomatis: php8.2 artisan key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com    # ganti dengan domain Anda

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=            # nama database di CloudPanel
DB_USERNAME=            # user database di CloudPanel
DB_PASSWORD=            # password database di CloudPanel

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database         # PENTING: pakai database (bukan sync) di production

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=respon@mitra-project.com
MAIL_PASSWORD=                    # isi password SMTP
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="respon@mitra-project.com"
MAIL_FROM_NAME="CDP NoReply"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"
